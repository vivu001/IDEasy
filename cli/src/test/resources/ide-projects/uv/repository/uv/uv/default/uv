#!/bin/bash
if [ "$1" = "python" ] && [ "$2" = "list" ]; then
  echo '[{"version": "3.14.6", "implementation": "cpython"}, {"version": "3.12.12", "implementation": "cpython"}, {"version": "7.3.17", "implementation": "pypy"}]'
  exit 0
fi
echo "uv $*"
cd $(dirname $0)
cd ../../../../../..
pwd
TOOLS_DB="project/software/.uv-installed-tools"
if [ "$1" = "pip" ] && [ "$2" = "install" ]; then
  cp repository/pip/pip/default/bin/pip project/software/python/bin
elif [ "$1" = "venv" ] && [ "$2" = "--python" ]; then
  cp -a repository/python/python/default project/software/.venv
elif [ "$1" = "tool" ] && [ "$2" = "install" ]; then
  echo "${!#}" >> "$TOOLS_DB"
elif [ "$1" = "tool" ] && [ "$2" = "list" ]; then
  if [ -f "$TOOLS_DB" ]; then
    while IFS= read -r spec; do
      name="${spec%@*}"
      version="${spec#*@}"
      echo "$name v$version"
      echo "- ${name}"
    done < "$TOOLS_DB"
  fi
fi
